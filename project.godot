; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RPG"
run/main_scene="res://scenes/game.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=144
config/icon="res://icon.svg"

[autoload]

GameTuning="*res://scripts/autoload/game_tuning.gd"
FreezeFrame="*uid://nq66c5nwjfv5"

[debug]

shader_language/warnings/treat_warnings_as_errors=true

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=4
window/size/resizable=false
window/size/no_focus=true
window/size/sharp_corners=true
window/size/minimize_disabled=true
window/size/maximize_disabled=true
window/subwindows/embed_subwindows=false
window/stretch/aspect="ignore"
window/stretch/scale=0.5
window/stretch/scale_mode="integer"
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[global_group]

Player=""

